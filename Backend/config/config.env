BACKEND_PORT=4000
FRONTEND_URL=http://localhost:5173

# Create a project and connect it with google dialog flow in GCP
# 1. Go to console.cloud.google.com
# 2. Select the same project linked to your Dialogflow ES agent
#  a. Open http://dialogflow.cloud.google.com/
#  b. Visit the "General" tab
#  c. The "Project ID" under "Google Project" is your project id
DIALOGFLOW_PROJECT_ID=your_project_id

# 1. Go to console.cloud.google.com
# 2. Select the same project linked to your Dialogflow ES agent
# 3. In the search bar, search "Service Accounts" and open it
# 4. Click "Create Service Account" and fill in the details.
# 5. Click "Create and Continue"
# 6. Under "Grant this service account access", add role: "Dialogflow API Client" and then click "Done"
# 7. Click on the service account you just created
# 8. Go to "Keys" tab
#  a. Click "Add Key" and then "Create New Key", then select JSON, and then "Create"
#  b. Move the downloaded file to the location below and name it as below
GOOGLE_APPLICATION_CREDENTIALS=./config/serviceAccount.json
